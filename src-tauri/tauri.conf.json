{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Jonggrang Tunnel",
  "version": "0.1.0",
  "identifier": "id.maia.jonggrang.tunnel",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "tsc",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../src"
  },
  "app": {
    "windows": [
      {
        "title": "Jonggrang Tunnel",
        "label": "main",
        "width": 900,
        "height": 660,
        "minWidth": 640,
        "minHeight": 480,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "appimage", "dmg", "app"],
    "category": "DeveloperTool",
    "shortDescription": "SSH tunnel GUI for jonggrang servers",
    "longDescription": "A Tauri v2 desktop app (macOS + Linux) providing a GUI for SSH local-port forwarding into a jonggrang server.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
