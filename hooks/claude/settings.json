{
  "_comment": "Jonggrang Claude Code hook settings. Copied to .claude/settings.json during jonggrang init.",
  "_note": "JONGGRANG_HOOKS_DIR is replaced with actual path during installation.",
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"JONGGRANG_HOOKS_DIR/session-init.sh\""
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Task",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"JONGGRANG_HOOKS_DIR/task-role-claim.sh\""
          },
          {
            "type": "command",
            "command": "bash \"JONGGRANG_HOOKS_DIR/compaction-gate.sh\""
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"JONGGRANG_HOOKS_DIR/agent-first.sh\""
          }
        ]
      },
      {
        "matcher": "Read|Edit|Write|Glob|Grep",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"JONGGRANG_HOOKS_DIR/block-sensitive-files.sh\""
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"JONGGRANG_HOOKS_DIR/block-secret-commands.sh\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"JONGGRANG_HOOKS_DIR/track-modifications.sh\""
          }
        ]
      },
      {
        "matcher": "Task",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"JONGGRANG_HOOKS_DIR/task-skill-enforcement.sh\""
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"JONGGRANG_HOOKS_DIR/sanitize-output.sh\""
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"JONGGRANG_HOOKS_DIR/output-enforcement.sh\""
          },
          {
            "type": "command",
            "command": "bash \"JONGGRANG_HOOKS_DIR/secret-final-check.sh\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"JONGGRANG_HOOKS_DIR/feedback-loop.sh\""
          },
          {
            "type": "command",
            "command": "bash \"JONGGRANG_HOOKS_DIR/quality-gate.sh\""
          }
        ]
      }
    ]
  }
}
